# YAOC2 root .env.example
# Actual runtime .env lives in infra/dockge/yaoc2-gateway/
# Brain variables are set in /opt/n8n.env on the n8n LXC (managed by n8n-ecosystem-unified)

# Shared secret between brain and gateway
GATEWAY_WEBHOOK_SECRET=changeme_shared_secret

# Timezone
TZ=America/Chicago
GENERIC_TIMEZONE=America/Chicago

# Network
N8N_LXC_IP=10.10.10.40
DOCKGE_CTI_LXC_IP=10.10.10.10
GATEWAY_PORT=5679

# infra-postgres upgrade note:
# threatlabs-cti-stack infra/docker-compose.yml postgres image should be:
#   pgvector/pgvector:pg17
# (was: postgres:17-alpine)
# Run infra/migrations/000_yaoc2_schema.sql after upgrading.
