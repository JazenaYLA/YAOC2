# Root-level .env.example — top-level shared variables
# Actual .env files live in infra/docker/n8n-brain/ and infra/docker/n8n-gateway/
# See those directories for service-specific variables.

# Shared secret between brain and gateway
GATEWAY_WEBHOOK_SECRET=changeme_shared_secret

# Timezone
TZ=America/Chicago
GENERIC_TIMEZONE=America/Chicago

# Proxmox network (adjust to match your cti-net)
CTI_NET_SUBNET=10.10.10.0/24
BRAIN_IP=10.10.10.50
GATEWAY_IP=10.10.10.51
