# =============================================================================
# YAOC2 — Root Environment Template
# Copy to .env and fill in all values before running scripts/setup.sh
# =============================================================================

# --- Proxmox Host ---
PVE_HOST=192.168.1.10          # Proxmox host IP
PVE_STORAGE=local-lvm          # Storage pool for LXC disks
PVE_TEMPLATE=debian-12-standard # CT template name
PVE_BRIDGE=vmbr0               # Network bridge

# --- LXC IP Assignments (adjust to your VLAN) ---
N8N_IP=192.168.1.21
FLOWISE_IP=192.168.1.22
POSTGRES_IP=192.168.1.23
VALKEY_IP=192.168.1.24
CADDY_IP=192.168.1.25
INFISICAL_IP=192.168.1.26
HEADSCALE_IP=192.168.1.27
DOCKGE_CTI_IP=192.168.1.28

# --- LXC Resource Defaults ---
DEFAULT_CORES=2
DEFAULT_RAM_MB=2048
DEFAULT_DISK_GB=20

# --- Shared Postgres ---
POSTGRES_PASSWORD=ChangeMeStrongPassword
POSTGRES_N8N_DB=n8n
POSTGRES_FLOWISE_DB=flowise
POSTGRES_YAOC2_DB=yaoc2_policy

# --- Shared Valkey / Redis ---
VALKEY_PASSWORD=ChangeMeValkey

# --- n8n ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=ChangeMeN8n
N8N_ENCRYPTION_KEY=ChangeMeEncryptionKey32chars
N8N_WEBHOOK_URL=http://n8n.yaoc2.local

# --- Flowise ---
FLOWISE_USERNAME=admin
FLOWISE_PASSWORD=ChangeMeFlowise

# --- Infisical ---
INFISICAL_ADMIN_EMAIL=admin@yaoc2.local
INFISICAL_ADMIN_PASSWORD=ChangeMeInfisical

# --- Headscale ---
HEADSCALE_BASE_DOMAIN=yaoc2.local
HEADSCALE_SERVER_URL=http://headscale.yaoc2.local

# --- OpenCTI / XTM ---
OPENCTI_ADMIN_EMAIL=admin@yaoc2.local
OPENCTI_ADMIN_PASSWORD=ChangeMeOpenCTI
OPENCTI_ADMIN_TOKEN=ChangeMe-UUID4-Token

# --- Shuffle ---
SHUFFLE_BACKEND_HOSTNAME=shuffle-backend
SHUFFLE_DEFAULT_USERNAME=admin
SHUFFLE_DEFAULT_PASSWORD=ChangeMeShuffle

# --- Caddy / DNS ---
BASE_DOMAIN=yaoc2.local

# --- Telegram (OpenClaw channel) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# --- External AI Provider (optional) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Policy Gateway ---
POLICY_APPROVAL_CHANNEL=telegram   # telegram | slack | email
POLICY_HIGH_RISK_AUTO_DENY=true     # deny high-risk without approval prompt
POLICY_AUDIT_LOG_DAYS=90
