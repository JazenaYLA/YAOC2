# n8n gateway instance environment variables
# Copy to .env and fill in values

POSTGRES_PASSWORD=changeme_gateway_db
N8N_ENCRYPTION_KEY=changeme_32char_random_string

# Public URL for this n8n instance (for webhooks)
GATEWAY_WEBHOOK_URL=https://10.10.10.51:5679/

# Shared secret with brain
GATEWAY_WEBHOOK_SECRET=changeme_shared_secret

# MISP
MISP_BASE_URL=https://10.10.10.20
MISP_API_KEY=your_misp_api_key

# OpenCTI
OPENCTI_BASE_URL=https://10.10.10.21:8080
OPENCTI_API_KEY=your_opencti_api_key

# TheHive
THEHIVE_BASE_URL=https://10.10.10.22:9000
THEHIVE_API_KEY=your_thehive_api_key

# Cortex
CORTEX_BASE_URL=https://10.10.10.23:9001
CORTEX_API_KEY=your_cortex_api_key

# Flowise
FLOWISE_BASE_URL=https://10.10.10.30:3000
FLOWISE_API_KEY=your_flowise_api_key

# Shuffle (in dockge-cti LXC)
SHUFFLE_BASE_URL=https://10.10.10.10:3001
SHUFFLE_API_KEY=your_shuffle_api_key

# XTM (in dockge-cti LXC)
XTM_BASE_URL=https://10.10.10.10:8080
XTM_API_KEY=your_xtm_api_key

# Telegram approval bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
APPROVAL_CHAT_ID=your_analyst_chat_id
