# n8n brain instance environment variables
# Copy to .env and fill in values

POSTGRES_PASSWORD=changeme_brain_db
N8N_ENCRYPTION_KEY=changeme_32char_random_string

# Public URL for this n8n instance (for webhooks)
BRAIN_WEBHOOK_URL=https://yaoc2-brain.example.internal/

# LLM provider (uncomment one)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OLLAMA_BASE_URL=http://10.10.10.XX:11434

# Gateway connection
GATEWAY_WEBHOOK_URL=https://10.10.10.51:5679/webhook/proposed-action
GATEWAY_WEBHOOK_SECRET=changeme_shared_secret

# Telegram bot (user-facing front-end)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
