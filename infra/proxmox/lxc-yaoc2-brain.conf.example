# YAOC2 Brain — Proxmox LXC reference
#
# The brain does NOT require a new LXC.
# Brain workflows are imported into the existing n8n LXC managed by
# n8n-ecosystem-unified:
#   https://github.com/JazenaYLA/n8n-ecosystem-unified
#
# This file is kept as a reference for the recommended n8n LXC spec
# if you are setting one up from scratch.

arch: amd64
cores: 4
memory: 4096
swap: 512
ostype: debian
hostname: n8n
onboot: 1
start: 1
unprivileged: 1

# Same VLAN/bridge as dockge-cti so brain can reach gateway :5679
net0: name=eth0,bridge=cti-net,ip=10.10.10.40/24,gw=10.10.10.1,firewall=1

# n8n is installed as a systemd service via Proxmox community helper script:
# bash -c "$(curl -fsSL https://github.com/community-scripts/ProxmoxVE/raw/main/ct/n8n.sh)"
# See n8n-ecosystem-unified for post-install configuration.
