# YAOC2 Gateway environment variables
# Copy to .env and fill in values before starting the Dockge stack.

# --- Database ---
# Uses infra-postgres (pgvector/pgvector:pg17) — the OPENCLAW_DB_PASSWORD
# variable is already in threatlabs-cti-stack infra/.env.example
# Create the yaoc2 DB user/database via infra/migrations/000_yaoc2_schema.sql
YAOC2_DB_PASSWORD=changeme   # must match OPENCLAW_DB_PASSWORD in infra/.env

# --- n8n core ---
N8N_ENCRYPTION_KEY=changeme_32char_random_string
GATEWAY_WEBHOOK_URL=https://n8n-gateway.lab.local

# --- Security ---
GATEWAY_WEBHOOK_SECRET=changeme_shared_secret   # must match brain .env
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# --- CTI services (Docker container names on cti-net) ---
# Adjust to match your actual threatlabs-cti-stack service/container names
MISP_BASE_URL=http://misp
MISP_API_KEY=your_misp_api_key

OPENCTI_BASE_URL=http://opencti:8080
OPENCTI_API_KEY=your_opencti_api_key

THEHIVE_BASE_URL=http://thehive:9000
THEHIVE_API_KEY=your_thehive_api_key

CORTEX_BASE_URL=http://cortex:9001
CORTEX_API_KEY=your_cortex_api_key

# Flowise runs on a separate LXC — use LXC IP
FLOWISE_BASE_URL=http://10.10.10.30:3000
FLOWISE_API_KEY=your_flowise_api_key

SHUFFLE_BASE_URL=http://shuffle-backend:3001
SHUFFLE_API_KEY=your_shuffle_api_key

XTM_BASE_URL=http://xtm:8080
XTM_API_KEY=your_xtm_api_key

# --- Approval notifications ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
APPROVAL_CHAT_ID=your_analyst_chat_id

# --- Policy ---
DEFAULT_POLICY_SET=default-threatlab
